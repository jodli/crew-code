{
  "name": "crew",
  "version": "0.2.0",
  "description": "CLI tool for managing Claude Code agent teams",
  "type": "module",
  "bin": {
    "crew": "./src/main.ts"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "build": "bun build --compile src/main.ts --outfile dist/crew",
    "test": "bun test src/{actions,adapters,api,cli,config,core,lib,runtime,tui,types}",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/web/tsconfig.json",
    "lint": "biome check src/",
    "format": "biome check --write src/",
    "web:dev": "vite --config src/web/vite.config.ts",
    "web:build": "vite build --config src/web/vite.config.ts",
    "web:test": "vitest --config src/web/vitest.config.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^5.2.2",
    "@opentui/core": "^0.1.94",
    "@opentui/react": "^0.1.94",
    "@tanstack/react-query": "^5.96.2",
    "citty": "^0.1.6",
    "cli-table3": "^0.6.5",
    "env-paths": "^3.0.0",
    "hono": "^4.12.8",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "yaml": "^2.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "happy-dom": "^20.8.9",
    "msw": "^2.12.14",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wouter": "^3.9.0"
  }
}
